// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// ENUMS
// =====================
enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum CourseStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum TeacherCourseRole {
  OWNER
  EDITOR
  VIEWER
}

enum GuideStatus {
  DRAFT
  PUBLISHED
}

// =====================
// MODELS
// =====================
model Institution {
  id      String  @id @default(cuid())
  name    String
  country String?
  city    String?
  isActive Boolean @default(true)

  users   User[]
  courses Course[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  role            UserRole
  requestedRole   String?   // "STUDENT" o "TEACHER"
  isActive        Boolean  @default(true)
  pendingApproval Boolean  @default(false)

  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])

  taughtCourses   CourseTeacher[]
  enrolledCourses CourseStudent[]
  refreshTokens   RefreshToken[]
  guidesCreated   Guide[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id           String       @id @default(cuid())
  name         String
  grade        String
  group        String
  academicYear String
  status       CourseStatus @default(ACTIVE)

  startsAt    DateTime
  endsAt      DateTime
  experiments CourseExperiment[]

  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  teachers CourseTeacher[]
  students CourseStudent[]
  guides   Guide[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId, status])
}

model CourseTeacher {
  id String @id @default(cuid())

  courseId  String
  teacherId String

  role TeacherCourseRole @default(OWNER)

  course  Course @relation(fields: [courseId], references: [id])
  teacher User   @relation(fields: [teacherId], references: [id])

  assignedAt DateTime @default(now())

  @@unique([courseId, teacherId])
}

model CourseStudent {
  id String @id @default(cuid())

  courseId  String
  studentId String

  course  Course @relation(fields: [courseId], references: [id])
  student User   @relation(fields: [studentId], references: [id])

  enrolledAt DateTime @default(now())

  @@unique([courseId, studentId])
}

model Guide {
  id          String     @id @default(cuid())
  title       String
  description String?
  fileUrl     String?

  status  GuideStatus @default(DRAFT)
  content Json?

  // Opcional: guías globales por experimento no pertenecen a ningún curso
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id])

  experimentId String?
  experiment   Experiment? @relation(fields: [experimentId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, status])
  @@index([createdById, status])
  @@index([experimentId])
}

model Experiment {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  visibility  String
  status      String
  order       Int

  courses   CourseExperiment[]
  guides    Guide[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CourseExperiment {
  id           String   @id @default(cuid())
  courseId     String
  experimentId String
  createdAt    DateTime @default(now())

  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@unique([courseId, experimentId])
  @@index([courseId])
  @@index([experimentId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  revokedAt DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}
